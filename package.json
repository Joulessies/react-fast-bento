    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@chromatic-com/storybook": "^3.2.2",
    "@eslint/js": "^9.13.0",
    "@jest/globals": "^29.7.0",
    "@storybook/addon-docs": "^8.4.7",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
