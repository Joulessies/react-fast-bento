{
  "name": "react-fast-bento",
  "version": "1.0.0",
  "description": "🍱 Lightweight React component for easy bento grid layouts and boxes.",
  "license": "ISC",
  "author": "Joulessies",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup src --format esm,cjs --dts --clean",
    "test": "vitest",
    "lint": "eslint --ext js,jsx,ts,tsx --ignore-pattern 'dist/*' --ignore-pattern 'documentation/.docusaurus/*' --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky || true",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.26.8",
    "@babel/preset-react": "^7.26.3",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@eslint/compat": "^1.2.6",
    "@eslint/js": "^9.21.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "@vitejs/plugin-react": "^4.3.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.21.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.4",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "prettier": "3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "rollup": "^4.34.6",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "react-grid-system": "^8.2.1",
    "tslib": "^2.8.1"
  }
}
